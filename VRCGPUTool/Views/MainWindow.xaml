<Window x:Class="VRCGPUTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        xmlns:b="clr-namespace:VRCGPUTool.Behaviors"
        Title="VRChat GPU Tool"
        Width="400" SizeToContent="Height"
        ResizeMode="CanMinimize"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Grid>

        <!-- タスクトレイアイコン -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="VRChat GPU Tool"
                        TrayLeftMouseUp="TrayIcon_TrayLeftMouseUp">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="ウィンドウを開く" Click="TrayMenu_Open_Click"/>
                    <Separator/>
                    <MenuItem Header="終了" Click="TrayMenu_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- メインレイアウト -->
        <DockPanel>

            <!-- ステータスバー -->
            <StatusBar DockPanel.Dock="Bottom" Height="24">
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem Grid.Column="0">
                    <TextBlock Text="{Binding StatusText}" />
                </StatusBarItem>
                <StatusBarItem Grid.Column="1">
                    <StackPanel Orientation="Horizontal">
                        <Separator Style="{StaticResource {x:Static StatusBar.SeparatorStyleKey}}" Margin="0,1"/>
                        <TextBlock Text="{Binding CurrentTimeText}"
                                   FontFamily="Yu Gothic UI" Margin="4,0,0,0"/>
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <!-- アップデートバナー  -->
            <Border DockPanel.Dock="Top"
                    Background="#FFF9C4" BorderBrush="#F9A825" BorderThickness="0,0,0,1"
                    Visibility="{Binding AvailableUpdate,
                                         Converter={StaticResource NullToCollapsedConverter}}">
                <DockPanel Margin="8,4">
                    <Button DockPanel.Dock="Right" Content="✕"
                            Command="{Binding DismissUpdateCommand}"
                            Padding="4,2" Margin="4,0,0,0"
                            Background="Transparent" BorderThickness="0"/>
                    <Button DockPanel.Dock="Right" Content="リリースページを開く"
                            Command="{Binding OpenReleasePageCommand}"
                            Padding="6,2" Margin="8,0,0,0"/>
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding AvailableUpdate.TagName,
                                              StringFormat='新しいバージョン {0} が利用可能です'}"/>
                </DockPanel>
            </Border>

            <!-- メインコンテンツ -->
            <StackPanel Margin="12,10,12,12">

                    <!-- GPUステータス -->
                    <GroupBox Header="GPU ステータス" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                                <TextBlock Text="コア温度" Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="{Binding CoreTempText}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                                <TextBlock Text="消費電力" Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="{Binding PowerDrawText}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                                <TextBlock Text="電力制限" Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="{Binding CurrentPlText}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                                <TextBlock Text="コアクロック" Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="{Binding CoreClockText}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                                <TextBlock Text="メモリクロック" Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="{Binding MemClockText}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="4">
                                <TextBlock Text="GPU 使用率" Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="{Binding GpuUtilText}" FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- スケジュール -->
                    <GroupBox Header="スケジュール" Margin="0,0,0,8">
                        <DockPanel Margin="0,4,0,0">
                            <Button DockPanel.Dock="Right"
                                    Content="編集"
                                    Command="{Binding OpenScheduleSettingCommand}"
                                    Padding="10,4"/>
                            <TextBlock Text="{Binding ScheduleSummaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                        </DockPanel>
                    </GroupBox>

                    <!-- 制限ステータス + 操作ボタン -->
                    <Border Background="{Binding IsLimiting,
                                                 Converter={StaticResource LimitStatusBrushConverter}}"
                            CornerRadius="4" Padding="8" Margin="0,0,0,8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="{Binding IsLimiting,
                                                      Converter={StaticResource LimitStatusTextConverter}}"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Content="制限開始" Command="{Binding ApplyLimitCommand}"
                                        Width="100" Height="32" Margin="0,0,6,0"
                                        Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                                <Button Content="制限解除" Command="{Binding RemoveLimitCommand}"
                                        Width="100" Height="32"
                                        Background="#F44336" Foreground="White" FontWeight="Bold"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ナビゲーション -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="設定"     Command="{Binding OpenSettingsCommand}"
                                Width="80" Margin="0,0,6,0"/>
                        <Button Content="電力履歴" Command="{Binding OpenPowerHistoryCommand}"
                                Width="80"/>
                    </StackPanel>

            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
