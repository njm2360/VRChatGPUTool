<Application x:Class="VRCGPUTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VRCGPUTool.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Converters -->
        <conv:NullToCollapsedConverter       x:Key="NullToCollapsedConverter"/>
        <conv:InverseBoolConverter           x:Key="InverseBoolConverter"/>
        <conv:BoolToVisibilityConverter      x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:LimitStatusTextConverter       x:Key="LimitStatusTextConverter"/>
        <conv:LimitStatusBrushConverter      x:Key="LimitStatusBrushConverter"/>
        <conv:RatioToGridLengthConverter     x:Key="RatioToGridLengthConverter"/>

        <!-- Styles -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="8,4,8,8"/>
        </Style>
    </Application.Resources>
</Application>
